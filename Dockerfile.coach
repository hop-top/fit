# syntax=docker/dockerfile:1

# ---------- Stage 1: Go CLI build ----------
FROM golang:1.26-alpine AS go-build

WORKDIR /src

COPY go/go.mod go/go.sum ./go/
RUN cd go && go mod download

COPY go/ ./go/

RUN cd go && CGO_ENABLED=0 go build \
      -ldflags="-s -w" \
      -o /usr/local/bin/fit \
      ./cmd/fit

# ---------- Stage 2: Python build ----------
FROM python:3.11-slim AS py-build

WORKDIR /src

COPY py/pyproject.toml py/README.md* ./
COPY py/src/ ./src/

RUN pip install --no-cache-dir --prefix=/install ".[adapters]"

# ---------- Stage 3: runtime ----------
FROM python:3.11-slim

LABEL org.opencontainers.image.title="fit-coach" \
      org.opencontainers.image.description="fit training pipeline — train advisors to steer LLMs" \
      org.opencontainers.image.url="https://github.com/hop-top/fit" \
      org.opencontainers.image.source="https://github.com/hop-top/fit" \
      org.opencontainers.image.vendor="hop-top" \
      org.opencontainers.image.licenses="MIT"

# Copy fit CLI binary
COPY --from=go-build /usr/local/bin/fit /usr/local/bin/fit

# Copy installed Python packages
COPY --from=py-build /install /usr/local

# Copy Python source (for -m invocation)
COPY py/src/ /app/src/
COPY py/examples/ /app/examples/

WORKDIR /app
ENV PYTHONPATH=/app/src

EXPOSE 8080

ENTRYPOINT ["python", "-m", "fit.training"]
