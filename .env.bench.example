# Benchmark environment configuration
# Copy to .env.bench and fill in values

# LLM API keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Proxy settings
FIT_BENCH_PORT=8781
FIT_BENCH_UPSTREAM=anthropic

# SWE-bench settings
SWEBENCH_DATASET=princeton-nlp/SWE-bench_Lite
SWEBENCH_MAX_WORKERS=4

# TAU-bench settings
TAU_DOMAIN=retail
TAU_MAX_CONCURRENCY=4

# Aider settings
AIDER_EXERCISES_DIR=vendor/polyglot-benchmark
AIDER_EDIT_FORMAT=diff
